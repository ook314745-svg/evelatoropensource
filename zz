local function UpdateButtonState()
    if isActive then
       
        ToggleBtn.Text = "ON"
        ToggleBtn.BackgroundColor3 = CONFIG.THEME.ON
        ToggleBtn.TextColor3 = CONFIG.THEME.TEXT
        BtnGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, CONFIG.THEME.PURPLE),
            ColorSequenceKeypoint.new(1, CONFIG.THEME.PURPLE_GLOW)
        })
        TweenService:Create(BtnGlow, TweenInfo.new(0.3), {ImageTransparency = 0.3}):Play()
        
        
        spawn(function()
            while isActive and ToggleBtn.Parent do
                TweenService:Create(BtnGlow, TweenInfo.new(0.6), {ImageTransparency = 0.1}):Play()
                task.wait(0.6)
                if not isActive then break end
                TweenService:Create(BtnGlow, TweenInfo.new(0.6), {ImageTransparency = 0.4}):Play()
                task.wait(0.6)
            end
        end)
    else
       
        ToggleBtn.Text = "OFF"
        ToggleBtn.BackgroundColor3 = CONFIG.THEME.OFF
        ToggleBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        BtnGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 50, 60)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(70, 70, 80))
        })
        TweenService:Create(BtnGlow, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
    end
end

local function OnToggleClicked()
    
    if isDragging then return end
    
    
    local now = tick()
    if now - lastToggle < CONFIG.DEBOUNCE then return end
    lastToggle = now
    
    
    isActive = not isActive
    
    
    if isActive then
        StartElevator()
    else
        StopElevator()
    end
    
    
    UpdateButtonState()
end

ToggleBtn.MouseButton1Click:Connect(OnToggleClicked)
ToggleBtn.TouchTap:Connect(OnToggleClicked)


player.CharacterRemoving:Connect(function()
    if isActive then
        isActive = false
        StopElevator()
        UpdateButtonState()
    end
end)


