local function SetupAntiKill(char)
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    humanoid.HealthChanged:Connect(function(health)
        if health <= 0 then humanoid.Health = humanoid.MaxHealth end
    end)
    for _, state in pairs({Enum.HumanoidStateType.Dead, Enum.HumanoidStateType.Physics}) do
        humanoid:SetStateEnabled(state, false)
    end
end


local function SpoofPhysics(hrp)
    hrp.Velocity = Vector3.new(hrp.Velocity.X, 0.1, hrp.Velocity.Z)
    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0.1, hrp.AssemblyLinearVelocity.Z)
end


local function StartElevator()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    SetupAntiKill(char)
    
    elevator = Instance.new("Part")
    elevator.Name = "Z_" .. tostring(math.random(100000,999999))
    elevator.Size = Vector3.new(3, 0.2, 3)
    elevator.Color = CONFIG.THEME.PURPLE
    elevator.Material = Enum.Material.Neon
    elevator.Transparency = 0.8
    elevator.Anchored = true
    elevator.CanCollide = true
    elevator.CanQuery = false
    elevator.CanTouch = false
    elevator.Parent = workspace
    
    local startY = hrp.Position.Y - 2
    elevator.CFrame = CFrame.new(hrp.Position.X, startY, hrp.Position.Z)
    
    connection = RunService.Heartbeat:Connect(function()
        if not isActive or not elevator or not elevator.Parent then return end
        local currentHRP = char:FindFirstChild("HumanoidRootPart")
        if not currentHRP then return end
        
        local currentPos = currentHRP.Position
        local currentRot = currentHRP.CFrame - currentHRP.CFrame.Position
        local newY = elevator.Position.Y + CONFIG.RISE_SPEED
        
        elevator.CFrame = CFrame.new(currentPos.X, newY, currentPos.Z)
        
        local targetY = newY + 3
        if targetY - currentPos.Y > 0.3 then
            currentHRP.CFrame = CFrame.new(currentPos.X, targetY, currentPos.Z) * currentRot
        end
        
        SpoofPhysics(currentHRP)
    end)
end

local function StopElevator()
    if connection then connection:Disconnect() connection = nil end
    if elevator then elevator:Destroy() elevator = nil end
end


